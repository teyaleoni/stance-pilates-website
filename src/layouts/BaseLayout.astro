---
import "../styles/global.css";
import Nav from "../components/Nav.astro";
import ContactInfo from "../components/ContactInfo.astro";
import {
  GA_MEASUREMENT_ID,
  PHONE_NUMBER,
  EMAIL_ADDRESS,
  INSTAGRAM_URL,
  GOOGLE_MAPS_URL,
  GOOGLE_BUSINESS_PROFILE_URL,
} from "../constants";

interface Props {
  title: string;
  description?: string;
  /** Prefix for nav anchor links: "" on the home page, "/" elsewhere. */
  navHrefPrefix?: string;
}

const { title, description, navHrefPrefix = "" } = Astro.props;

const siteUrl = "https://stancepilates.com";

// LocalBusiness structured data so search engines and AI can read the
// studio's identity, location, and classical Pilates focus directly.
const structuredData = {
  "@context": "https://schema.org",
  "@type": "HealthClub",
  "@id": `${siteUrl}/#studio`,
  name: "Stance Pilates",
  description:
    "Private, one-on-one classical Pilates studio in Southwest Las Vegas, training clients on the full Contrology apparatus suite (Reformer, Cadillac, Wunda Chair, Ladder Barrel).",
  url: siteUrl,
  image: `${siteUrl}/icons/icon-512.png`,
  logo: `${siteUrl}/icons/icon-512.png`,
  telephone: `+1-${PHONE_NUMBER}`,
  email: EMAIL_ADDRESS,
  priceRange: "$$",
  address: {
    "@type": "PostalAddress",
    streetAddress: "6675 S Tenaya Way #200",
    addressLocality: "Las Vegas",
    addressRegion: "NV",
    postalCode: "89113",
    addressCountry: "US",
  },
  areaServed: [
    "Southwest Las Vegas",
    "South Summerlin",
    "Rhodes Ranch",
    "Mountain's Edge",
    "Spring Valley",
  ],
  founder: { "@type": "Person", name: "Teya Lorts" },
  hasMap: GOOGLE_MAPS_URL,
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: "Tuesday",
      opens: "11:00",
      closes: "19:00",
    },
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: "Thursday",
      opens: "15:00",
      closes: "19:00",
    },
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: "Saturday",
      opens: "09:00",
      closes: "13:00",
    },
  ],
  sameAs: [INSTAGRAM_URL, GOOGLE_BUSINESS_PROFILE_URL, GOOGLE_MAPS_URL],
  knowsAbout: [
    "Classical Pilates",
    "Contrology",
    "Pilates Reformer",
    "Cadillac trapeze table",
    "Wunda Chair",
    "Ladder Barrel",
    "Private Pilates instruction",
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />

    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="rgb(241, 238, 234)" />
    <meta name="generator" content={Astro.generator} />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;500&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Jost:wght@400&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Lato:wght@300;400&display=swap"
    />

    <!-- Google tag (gtag.js) -->
    <script
      is:inline
      async
      src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}
    ></script>
    <script is:inline define:vars={{ GA_MEASUREMENT_ID }}>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", GA_MEASUREMENT_ID);
    </script>
  </head>
  <body>
    <div class="app-shell">
      <Nav navHrefPrefix={navHrefPrefix} />
      <main id="scroll">
        <slot />
        <ContactInfo />
      </main>
    </div>
  </body>
</html>
