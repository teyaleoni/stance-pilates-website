---
import { BOOKING_URL } from "../constants";

interface Props {
  heading?: string;
  bundleSize?: number;
  bundleSizeDuet?: number;
  price: number;
  endDate?: string;
  expiry?: string;
  cta: string;
  noSavingsBadge?: boolean;
  highlight?: boolean;
  tag?: string;
  hidePerSession?: boolean;
  "aria-label"?: string;
}

const {
  heading,
  bundleSize,
  bundleSizeDuet,
  price,
  endDate,
  expiry,
  cta,
  noSavingsBadge = false,
  highlight = false,
  tag,
  hidePerSession = false,
  "aria-label": ariaLabel,
} = Astro.props;

const singleSessionPrice = 100;
const savings = (bundleSize ?? 0) * singleSessionPrice - price;
const showBadge = savings > 0 && !noSavingsBadge;

const showPerSession = !!bundleSize && bundleSize > 1 && !hidePerSession;
const perSession = showPerSession ? Math.round(price / bundleSize) : 0;

const title = heading
  ? heading
  : bundleSizeDuet
    ? bundleSizeDuet === 1
      ? "Duet Session"
      : `${bundleSizeDuet}-Session Bundle`
    : bundleSize === 1
      ? "Single Session"
      : `${bundleSize}-Session Bundle`;

const finalLabel =
  ariaLabel ||
  `Purchase ${heading || (bundleSize ? `${bundleSize}-Session Bundle` : "Session")}`;
---

<div
  class:list={[
    "card",
    "elevated",
    "pricing-card",
    { "pricing-card-highlight": highlight },
  ]}
>
  {showBadge && <div class="savings-badge">Save ${savings}</div>}
  {tag && <span class="pricing-tag">{tag}</span>}

  <div class="pricing-card-head">
    <h3 class="pricing-card-title">{title}</h3>
    <p class="pricing-price">
      ${price}
      {bundleSizeDuet && <span class="pricing-price-unit">/ person</span>}
    </p>
    {
      showPerSession && (
        <p class="pricing-per-session">${perSession} / session</p>
      )
    }
  </div>

  <div class="pricing-card-desc"><slot /></div>

  <p class="pricing-card-expiry">
    {endDate ? `Valid through ${endDate}` : `Expires in ${expiry}`}
  </p>

  <a href={BOOKING_URL} class="button pricing-card-cta" aria-label={finalLabel}>
    {cta}
  </a>
</div>
