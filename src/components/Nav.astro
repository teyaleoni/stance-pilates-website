---
import logo from "../assets/stance-logo.svg";
import MenuIcon from "./icons/MenuIcon.astro";
import { BOOKING_URL } from "../constants";

interface Props {
  /** "" on the home page (same-page anchors), "/" elsewhere. */
  navHrefPrefix?: string;
}

const { navHrefPrefix = "" } = Astro.props;
const p = navHrefPrefix;
---

<header class="wide">
  <div class="logo-link">
    <a href="/" style="display: contents;">
      <img
        src={logo.src}
        alt="stance pilates logo"
        width="100%"
        style="min-width: 100px;"
      />
    </a>
  </div>
  <nav class="gap-0 lg:gap-4">
    <a href={`${p}#about`}>About</a>
    <a href={`${p}#pricing`}>Pricing</a>
    <a href={`${p}events`}>Events</a>
    <a href={`${p}#faq`}>FAQ</a>
    <a href="#contact">Contact</a>
    <a href={`${p}blog`}>Blog</a>
    <a target="_blank" href={BOOKING_URL}>Book</a>
  </nav>
  <div class="logo-mirror-space">
    <img src={logo.src} alt="stance pilates logo" width="100%" />
  </div>
</header>

<header class="narrow" style="height: 40px; padding-right: 40px;">
  <div class="logo-link">
    <a href="/" style="display: contents;">
      <img src={logo.src} alt="stance pilates logo" width="100%" />
    </a>
  </div>
  <button
    type="button"
    id="nav-toggle"
    aria-label="Toggle navigation menu"
    style="position: absolute; padding: 10px; right: 0;"
  >
    <MenuIcon />
  </button>
</header>

<nav id="nav-drawer" class="closed gap-4">
  <a href={`${p}#about`}>About</a>
  <a href={`${p}#pricing`}>Pricing</a>
  <a href={`${p}events`}>Events</a>
  <a href={`${p}#faq`}>FAQ</a>
  <a href="#contact">Contact</a>
  <a href={`${p}blog`}>Blog</a>
  <a target="_blank" href={BOOKING_URL}>Book</a>
</nav>

<style>
  .logo-link {
    display: grid;
    padding-top: 4px;
    align-items: center;
  }
</style>

<script>
  const drawer = document.getElementById("nav-drawer");
  const toggle = document.getElementById("nav-toggle");

  toggle?.addEventListener("click", (e) => {
    e.preventDefault();
    e.stopPropagation();
    drawer?.classList.toggle("closed");
  });

  // Clicking anywhere else, or pressing Escape, closes the drawer.
  document.addEventListener("click", () => drawer?.classList.add("closed"));
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") drawer?.classList.add("closed");
  });
</script>
